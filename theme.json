{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"custom": false,
			"customDuotone": false,
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"duotone": [],
			"palette": [
				{
					"color": "#111111",
					"name": "Preto",
					"slug": "preto"
				},
				{
					"color": "#52A6E5",
					"name": "Azul",
					"slug": "azul"
				},
				{
					"color": "#81C9FF",
					"name": "Azul Claro",
					"slug": "azul-claro"
				},
				{
					"color": "#DEB745",
					"name": "Amarelo",
					"slug": "amarelo"
				},
				{
					"color": "#001930",
					"name": "Azul Escuro",
					"slug": "azul-escuro"
				},
				{
					"color": "#FFFFFF",
					"name": "Branco",
					"slug": "branco"
				}
			]
		},
		"custom": {
			"blockGap": "var(--wp--preset--spacing--24)"
		},
		"layout": {
			"contentSize": "1440px",
			"wideSize": "100%"
		},
		"shadow": {
			"presets": [
				{
					"name": "Padrão",
					"shadow": "2px 2px 10px 0px rgba(0, 0, 0, 0.20)",
					"slug": "start-default"
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "2X-Small",
					"size": "clamp(0.125rem, 10vw, 0.125rem)",
					"slug": "2"
				},
				{
					"name": "X-Small",
					"size": "clamp(0.2rem, 10vw, 0.25rem)",
					"slug": "4"
				},
				{
					"name": "Small",
					"size": "clamp(0.4rem, 10vw, 0.5rem)",
					"slug": "8"
				},
				{
					"name": "Medium",
					"size": "clamp(.75em, 10vw, 1rem)",
					"slug": "16"
				},
				{
					"name": "Large",
					"size": "clamp(1.25rem, 10vw, 1.5rem)",
					"slug": "24"
				},
				{
					"name": "X-Large",
					"size": "clamp(1.75rem, 10vw, 2rem)",
					"slug": "32"
				},
				{
					"name": "2X-Large",
					"size": "clamp(3rem, 10vw , 4rem)",
					"slug": "64"
				}
			]
		},
		"typography": {
			"customFontSize": true,
			"defaultFontSizes": false,
			"dropCap": false,
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Poppins",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/poppins/poppins-400-normal.woff2"
							]
						},
						{
							"fontFamily": "Poppins",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/poppins/poppins-700-normal.woff2"
							]
						}
					],
					"fontFamily": "Poppins, sans-serif",
					"name": "Poppins",
					"slug": "poppins"
				}
			],
			"fontSizes": [
				{
					"fluid": false,
					"name": "Tiny",
					"size": "0.625rem",
					"slug": "tiny"
				},
				{
					"fluid": false,
					"name": "Small",
					"size": "0.75rem",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "1rem",
						"min": "0.9rem"
					},
					"name": "Base",
					"size": "1rem",
					"slug": "base"
				},
				{
					"fluid": {
						"max": "1.15rem",
						"min": "1rem"
					},
					"name": "H6",
					"size": "1.15rem",
					"slug": "start-h6"
				},
				{
					"fluid": {
						"max": "1.5rem",
						"min": "1.15rem"
					},
					"name": "H5",
					"size": "1.5rem",
					"slug": "start-h5"
				},
				{
					"fluid": {
						"max": "1.5rem",
						"min": "1.25rem"
					},
					"name": "H4",
					"size": "1.5rem",
					"slug": "start-h4"
				},
				{
					"fluid": {
						"max": "1.75rem",
						"min": "1.5rem"
					},
					"name": "H3",
					"size": "1.75rem",
					"slug": "start-h3"
				},
				{
					"fluid": {
						"max": "2.25rem",
						"min": "1.75rem"
					},
					"name": "H2",
					"size": "2.25rem",
					"slug": "start-h2"
				},
				{
					"fluid": {
						"max": "2.72rem",
						"min": "2rem"
					},
					"name": "H1",
					"size": "2.72rem",
					"slug": "start-h1"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"core/accordion": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--16)",
					"margin": {
						"bottom": "0",
						"top": "0"
					},
					"padding": {
						"bottom": "0",
						"left": "0",
						"right": "0",
						"top": "0"
					}
				}
			},
			"core/column": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--24)",
					"padding": {
						"bottom": "0",
						"left": "0",
						"right": "0",
						"top": "0"
					}
				}
			},
			"core/columns": {
				"spacing": {
					"blockGap": {
						"left": "var(--wp--preset--spacing--16)",
						"top": "var(--wp--preset--spacing--8)"
					},
					"margin": {
						"bottom": "0",
						"top": "0"
					},
					"padding": {
						"bottom": "0",
						"left": "0",
						"right": "0",
						"top": "0"
					}
				}
			},
			"core/group": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--16)",
					"margin": {
						"bottom": "0",
						"top": "0"
					},
					"padding": {
						"bottom": "var(--wp--preset--spacing--64)",
						"left": "var(--wp--preset--spacing--16)",
						"right": "var(--wp--preset--spacing--16)",
						"top": "var(--wp--preset--spacing--64)"
					}
				}
			},
			"core/paragraph": {
				"spacing": {
					"margin": {
						"bottom": "var(--wp--preset--spacing--8)",
						"top": "var(--wp--preset--spacing--8)"
					}
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var( --wp--preset--color--black)"
		},
		"elements": {
			"button": {
				":active": {
					"color": {
						"background": "var(--wp--preset--color--white)",
						"text": "var(--wp--preset--color--secondary)"
					}
				},
				":focus": {
					"border": {
						"color": "var(--wp--preset--color--white)"
					},
					"color": {
						"background": "var(--wp--preset--color--secondary)",
						"text": "var(--wp--preset--color--white)"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--secondary)",
						"text": "var(--wp--preset--color--white)"
					}
				},
				":visited": {
					"color": {
						"text": "var(--wp--preset--color--white)"
					}
				},
				"border": {
					"color": "var(--wp--preset--color--white)",
					"radius": "0px",
					"width": "2px"
				},
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--white)"
				},
				"spacing": {
					"padding": {
						"bottom": "var(--wp--preset--spacing--8)",
						"left": "var(--wp--preset--spacing--24)",
						"right": "var(--wp--preset--spacing--24)",
						"top": "var(--wp--preset--spacing--8)"
					}
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--start-h-1)",
					"lineHeight": "1.1"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--start-h-2)",
					"lineHeight": "1.1"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--start-h-3)",
					"lineHeight": "1.2"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--start-h-4)",
					"lineHeight": "1.3"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--start-h-5)",
					"lineHeight": "1.4"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--start-h-6)",
					"lineHeight": "1.5"
				}
			},
			"heading": {
				"typography": {
					"fontWeight": "400",
					"lineHeight": "1.2"
				}
			},
			"link": {
				":active": {
					"color": {
						"text": "var( --wp--preset--color--black)"
					},
					"typography": {
						"textDecoration": "none"
					}
				},
				":focus": {
					"typography": {
						"textDecoration": "underline dashed"
					}
				},
				":hover": {
					"color": {
						"text": "var( --wp--preset--color--black)"
					},
					"typography": {
						"textDecoration": "underline"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"textDecoration": "underline"
				}
			}
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--16)",
			"padding": {
				"bottom": "var(--wp--preset--spacing--16)",
				"left": "var(--wp--preset--spacing--16)",
				"right": "var(--wp--preset--spacing--16)",
				"top": "var(--wp--preset--spacing--16)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--poppins)",
			"fontSize": "16px",
			"lineHeight": "1.6"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer Credit Area"
		},
		{
			"area": "uncategorized",
			"name": "comments",
			"title": "Comments"
		},
		{
			"area": "uncategorized",
			"name": "post-meta",
			"title": "Post Meta"
		}
	]
}